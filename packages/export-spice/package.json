{
  "name": "@runiq/export-spice",
  "version": "1.2.0",
  "description": "SPICE netlist exporter for Runiq Schematic profiles",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:examples": "node scripts/test-examples.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "spice",
    "netlist",
    "schematic",
    "export"
  ],
  "author": "Runiq Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quipolabs/runiq.git",
    "directory": "packages/export-spice"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@runiq/core": "^1.2.0"
  },
  "devDependencies": {
    "@runiq/parser-dsl": "^1.2.0",
    "eslint": "^9.37.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}

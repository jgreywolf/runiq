{
  "name": "@runiq/export-bpmn",
  "version": "1.2.0",
  "description": "BPMN XML exporter/importer (minimal subset) for Runiq diagrams",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "bpmn",
    "xml",
    "export",
    "import"
  ],
  "author": "Runiq Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quipolabs/runiq.git",
    "directory": "packages/export-bpmn"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@runiq/core": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  }
}

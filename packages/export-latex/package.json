{
  "name": "@runiq/export-latex",
  "version": "1.3.0",
  "description": "LaTeX/TikZ exporter for Runiq Control system diagrams",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "latex",
    "tikz",
    "control-systems",
    "export"
  ],
  "author": "Runiq Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quipolabs/runiq.git",
    "directory": "packages/export-latex"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@runiq/core": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.3"
  }
}
